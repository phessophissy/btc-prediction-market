{
  "name": "btc-prediction-market",
  "version": "1.0.0",
  "description": "Bitcoin-Anchored Prediction Market on Stacks",
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:node": "vitest run --config vitest.node.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:market-status": "vitest run tests/unit/market-status.test.ts",
    "clarinet:check": "clarinet check",
    "clarinet:test": "clarinet test",
    "clarinet:console": "clarinet console",
    "validate:json": "node -e \"JSON.parse(require('fs').readFileSync('package.json','utf8')); JSON.parse(require('fs').readFileSync('tsconfig.json','utf8')); console.log('json ok')\"",
    "generate:wallets": "npx ts-node scripts/generate-test-wallets.ts",
    "fund:wallets": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/fund-wallets.ts",
    "mainnet:interact": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/mainnet-interactions.ts",
    "mainnet:status": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' -e \"require('./scripts/mainnet-interactions').getMarketCount().then(console.log)\""
  },
  "devDependencies": {
    "@hirosystems/clarinet-sdk": "^2.3.2",
    "@stacks/transactions": "^6.13.0",
    "chokidar-cli": "^3.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0",
    "vitest-environment-clarinet": "^2.0.0"
  },
  "dependencies": {
    "@stacks/common": "^7.3.1",
    "@stacks/encryption": "^7.3.1",
    "@stacks/network": "^6.13.0",
    "@stacks/wallet-sdk": "^7.2.0",
    "dotenv": "^17.4.1"
  }
}
