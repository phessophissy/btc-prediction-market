dist/
.cache/
.next/
frontend/.next/
.vercel/
*.tsbuildinfo

# ───────────────────────────────────────────────
# Environment files — NEVER commit
# ───────────────────────────────────────────────
.env
.env.local
.env.*.local
.env*.local

# ───────────────────────────────────────────────
# Secrets / keys / wallets — NEVER commit
# ───────────────────────────────────────────────
# Key-derivation & funding scripts (read wallet mnemonics / private keys)
derive-master.ts
derive-funder.ts
# Wallet dumps (contain mnemonics / private keys)
wallets.json
wallets-*.json
*.wallet.json
scripts/mainnet-wallets.json
scripts/test-wallets.json
scripts/fund-wallets.ts
# Clarinet network configs (may embed deployer keys)
settings/Mainnet.toml
settings/Devnet.toml
settings/Testnet.toml
# Generic secret/key material
*.pem
*.key
*.keystore
*.p12
*.pfx
mnemonic*.txt
secret*.txt

# ───────────────────────────────────────────────
# Scripts & local tooling (not part of the shipped app)
# ───────────────────────────────────────────────
*.sh
scripts/
!tests/

# ───────────────────────────────────────────────
# Logs
# ───────────────────────────────────────────────
*.log
npm-debug.log*

# ───────────────────────────────────────────────
# Test coverage
# ───────────────────────────────────────────────
coverage/

# ───────────────────────────────────────────────
# IDE / OS
# ───────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db

# ───────────────────────────────────────────────
# Misc JSON at repo root (allowlist real package/config files)
# ───────────────────────────────────────────────
*.json
!package.json
!package-lock.json
!tsconfig.json
!Clarinet.toml
!frontend/package.json
!frontend/package-lock.json
